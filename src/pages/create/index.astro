---
import { db, Intros, Types } from 'astro:db';
import '../../styles/index.css';
import '../../styles/create-page.css';
import MainLayout from '../../layouts/MainLayout.astro';
import NewSayingForm from '../../components/NewSayingForm.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getSession } from 'auth-astro/server';
import type { IntroType, SayingType } from '../../types/saying';
import { actions } from 'astro:actions';

// Get the current user's session
const session = await getSession(Astro.request);

// Redirect to login if not authenticated
if (!session) {
  return Astro.redirect('/auth/signin?redirect=/create');
}

// --- Handle Action Result and Redirect ---
// Use the GLOBAL Astro object
const result = Astro.getActionResult(actions.submitSaying);
if (result && !result.error && result.data?.success && result.data.createdId) {
  return Astro.redirect(`/saying/${result.data.createdId}`);
}
// If there was an error, Astro Actions may display it near form fields.
// Optionally, handle `result.error` here for custom display if needed.
// let actionError = result?.error?.message; // Example
// --- End Action Result Handling ---

// Fetch data from database for form population
const introsData = (await db.select().from(Intros)) as IntroType[];
const typesData = (await db.select().from(Types)) as SayingType[];

// Map data to the format expected by the NewSayingForm component
const intros = introsData.map((intro) => ({
  id: Number(intro.id),
  introText: intro.introText,
}));

const types = typesData.map((type) => ({
  id: Number(type.id),
  typeName: type.name,
}));

// Don't prerender so we always get fresh data
export const prerender = false;
---

<MainLayout>
  <div class="container mx-auto max-w-4xl px-4">
    <PageHeader title="Create a New Saying" />

    <div class="mt-2 mb-8 p-8 bg-white dark:bg-gray-800 rounded-xl shadow-md">
      <NewSayingForm intros={intros} types={types} />
    </div>
  </div>
</MainLayout>
